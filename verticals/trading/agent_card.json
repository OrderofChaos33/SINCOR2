{
  "name": "SINCOR2 Trading Intelligence Pack",
  "description": "Prediction market and trading support for signal generation, market evaluation, and disciplined position sizing.",
  "version": "1.0.0",
  "supportedInterfaces": [
    {
      "url": "https://getsincor.com/api/a2a",
      "protocolBinding": "JSONRPC",
      "protocolVersion": "1.0.1"
    }
  ],
  "provider": {
    "organization": "SINCOR2",
    "url": "https://getsincor.com"
  },
  "capabilities": {
    "streaming": true,
    "pushNotifications": false,
    "stateTransitionHistory": true
  },
  "defaultInputModes": [
    "application/json"
  ],
  "defaultOutputModes": [
    "application/json"
  ],
  "skills": [
    {
      "id": "openclaw-trading",
