{
  "name": "Healthcare Credentialing Agent",
  "description": "Automates provider credentialing, CAQH enrollment, payer enrollment, and license tracking for healthcare operators.",
  "version": "1.0.1",
  "supportedInterfaces": [
    {
      "url": "https://credentialing.example.com/api/a2a",
      "protocolBinding": "JSONRPC",
      "protocolVersion": "1.0.1"
    }
  ],
  "provider": {
    "organization": "Example Healthcare Ops",
    "url": "https://credentialing.example.com"
  },
  "capabilities": {
    "streaming": false,
    "pushNotifications": true,
    "stateTransitionHistory": true
  },
  "defaultInputModes": [
    "application/json"
  ],
  "defaultOutputModes": [
    "application/json"
  ],
  "skills": [
    {
      "id": "caqh-enrollment",
      "name": "CAQH Enrollment",
      "description": "Initiates and tracks CAQH profile completion and attestations.",
      "tags": [
        "healthcare",
        "credentialing",
        "caqh"
      ],
      "examples": [
        "Create a CAQH onboarding packet for a new provider."
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ]
    },
    {
      "id": "payer-enrollment",
      "name": "Payer Enrollment",
      "description": "Coordinates payer rostering and enrollment packet submission.",
      "tags": [
        "healthcare",
        "payer-enrollment",
        "credentialing"
      ],
      "examples": [
        "Submit enrollment to a commercial payer."
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ]
    },
    {
      "id": "license-surveillance",
      "name": "License Surveillance",
      "description": "Monitors expiring state licenses and alerts operations teams.",
      "tags": [
        "healthcare",
        "license",
        "compliance"
      ],
      "examples": [
        "List licenses expiring in the next 60 days."
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ]
    }
  ],
  "securitySchemes": {
    "apiKey": {
      "type": "apiKey",
      "in": "header",
      "name": "X-API-Key"
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "documentationUrl": "https://credentialing.example.com/docs"
}
