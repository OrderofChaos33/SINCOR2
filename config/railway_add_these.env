# Railway → web service → Variables (paste new keys; update blanks on existing keys)
# Volume: Service → Volumes → Add Volume → mount path /data (1–5 GB)

SINCOR_DATA_DIR=/data
WEBBUILDER_DATA_DIR=/data/webbuilder
ORDERS_DB_PATH=/data/orders.db

# Safety — keep false on Railway (on-chain ops are local scripts only)
AGENT_BURN_AUTO=false
ALLOW_ONCHAIN_WRITES=false
SAFETY_OVERRIDE=false

# Token billing (required)
LEGACY_FIAT_PAYMENTS_ENABLED=false
PLATFORM_TREASURY_ADDRESS=0x09E2891432827D8835d2E9b83B25e2a5ba9612Ac
BASE_RPC_URL=
AXM_REPORT_PRICE=500
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Compliance monitor — confidential internal audit (no Slack/email/webhooks)
COMPLIANCE_MONITOR_ENABLED=true
COMPLIANCE_CONFIDENTIAL=true
COMPLIANCE_LOG_TO_STDOUT=false

# Launch ops + daily monitoring
LAUNCH_OPS_ENABLED=true
LAUNCH_OPS_INTERVAL_HOURS=24
LAUNCH_REVIEW_ALERT_EMAIL=eenergy@protonmail.com
LAUNCH_REVIEW_REMINDER_ENABLED=true
LAUNCH_REVIEW_REMINDER_HOUR=9
LAUNCH_REVIEW_REMINDER_MINUTE=15
DAILY_OPS_ENABLED=true
DAILY_OPS_INTERVAL_HOURS=24
SUBSCRIPTION_REMINDER_ENABLED=true

# Email (Resend powers compliance + subscription alerts)
RESEND_API_KEY=
SUPPORT_EMAIL=support@getsincor.com

# Alias — outreach reads GOOGLE_PLACES_API_KEY (copy same value as GOOGLE_PLACES_KEY)
GOOGLE_PLACES_API_KEY=

# OAuth (register callbacks in Google Cloud + GitHub OAuth App)
# Google: https://getsincor.com/auth/google/callback
# GitHub: https://getsincor.com/auth/github/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=https://getsincor.com
TRUST_PROXY=true

# Launch partner outreach (KOL / curators — July 7)
PARTNER_OUTREACH_ENABLED=true
PARTNER_OUTREACH_REMINDER_HOUR=8
PARTNER_OUTREACH_REMINDER_MINUTE=30
PARTNER_OUTREACH_ALERT_EMAIL=eenergy@protonmail.com

# Mobile wallet connect on /sinc — free project ID at https://cloud.reown.com
WALLETCONNECT_PROJECT_ID=

# Optional when ready
# CONTENT_AGENT_ENABLED=true
# OUTREACH_ENABLED=true
# NEYNAR_API_KEY=
# FARCASTER_SIGNER_UUID=