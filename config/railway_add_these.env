# Railway → web service → Variables (paste new keys; update blanks on existing keys)
# Volume: Service → Volumes → Add Volume → mount path /data (1–5 GB)

SINCOR_DATA_DIR=/data
WEBBUILDER_DATA_DIR=/data/webbuilder
ORDERS_DB_PATH=/data/orders.db

# Token billing (required)
LEGACY_FIAT_PAYMENTS_ENABLED=false
PLATFORM_TREASURY_ADDRESS=0x09E2891432827D8835d2E9b83B25e2a5ba9612Ac
BASE_RPC_URL=
AXM_REPORT_PRICE=500
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Compliance monitor — 30 min marketing/env audit
COMPLIANCE_MONITOR_ENABLED=true
COMPLIANCE_ALERT_EMAIL=eenergy@protonmail.com
APP_BASE_URL=https://getsincor.com
# SLACK_COMPLIANCE_WEBHOOK_URL=

# Launch ops + daily monitoring
LAUNCH_OPS_ENABLED=true
LAUNCH_OPS_INTERVAL_HOURS=24
LAUNCH_REVIEW_ALERT_EMAIL=eenergy@protonmail.com
LAUNCH_REVIEW_REMINDER_ENABLED=true
LAUNCH_REVIEW_REMINDER_HOUR=9
LAUNCH_REVIEW_REMINDER_MINUTE=15
DAILY_OPS_ENABLED=true
DAILY_OPS_INTERVAL_HOURS=24
SUBSCRIPTION_REMINDER_ENABLED=true

# Email (Resend powers compliance + subscription alerts)
RESEND_API_KEY=
SUPPORT_EMAIL=support@getsincor.com

# Alias — outreach reads GOOGLE_PLACES_API_KEY (copy same value as GOOGLE_PLACES_KEY)
GOOGLE_PLACES_API_KEY=

# Optional when ready
# CONTENT_AGENT_ENABLED=true
# OUTREACH_ENABLED=true
# NEYNAR_API_KEY=
# FARCASTER_SIGNER_UUID=