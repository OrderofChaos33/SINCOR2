# SINC Deploy - .env example (DO NOT commit secrets to git)
# Copy this to .env and populate with real values before running deploy scripts.

# RPC endpoint for Base mainnet
BASE_RPC_URL=

# Deployer private key (0x...); keep secret, never commit
DEPLOYER_PRIVATE_KEY=

# Router address (UniswapV2-style) for add_liquidity_eth.js / swap scripts
UNISWAP_V2_ROUTER=

# If using Uniswap V3 concentrated liquidity
UNISWAP_V3_ROUTER=
UNISWAP_V3_POSITION_MANAGER=

# Treasury address to receive minted SINC
TREASURY_ADDRESS=

# Price estimate for ETH in USD (used for estimating target ETH amount)
ETH_USD_EST=2000

# Amount of ETH to forward after swaps (e.g., 2.5 for ~ $5k at $2k/ETH)
FORWARD_ETH_AMOUNT=2.5

# (Optional) Market maker / operator private key for ongoing bots (keep secret)
MARKET_MAKER_PRIVATE_KEY=

# For safety, set FORCE_DEMO=1 to run in demo mode (no chain ops)
FORCE_DEMO=0
