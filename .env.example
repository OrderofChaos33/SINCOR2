# Incremental capital policy — NO fixed dollar ceiling. Start at $20 and every
# limit scales with equity (starting capital + realized profit):
#   $20    → ~$1–$3 wagers
#   $3,000 → ~$30–$300 wagers
# Stronger TOA/forecast confidence → larger fraction of the range, always.
POLYCLAW_CAPITAL_USD=20
POLYCLAW_MAX_POSITION_PCT=0.15
POLYCLAW_DAILY_LOSS_PCT=0.25
# Wager floor = Polymarket's ≈$1 exchange minimum.
POLYCLAW_MIN_WAGER_USD=1.0
POLYCLAW_MIN_EDGE=0.04
POLYCLAW_MIN_CONFIDENCE=0.4
POLYCLAW_KELLY_FRACTION=0.5
POLYCLAW_MAX_TRADES_PER_CYCLE=3
POLYCLAW_CYCLE_INTERVAL_SEC=90
POLYCLAW_HALT_FILE=/data/POLYCLAW_HALT