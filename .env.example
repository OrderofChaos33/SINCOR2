# ============================================================================
# SINCOR2 Environment Configuration Template
# ============================================================================
# Copy this to .env and fill in real values before deployment
# NEVER commit .env to version control

# ============================================================================
# Flask & Security
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256

# ============================================================================
# Admin Credentials (Change immediately after first login)
# ============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe!12345

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8080
HOST=0.0.0.0
WORKERS=2
TIMEOUT=180
TRUST_PROXY=true
RAILWAY_ENVIRONMENT=

# ============================================================================
# Database
# ============================================================================
SINCOR_DATA_DIR=/data
ORDERS_DB_PATH=/data/orders.db
DATABASE_URL=sqlite:////data/orders.db
SINCOR_STORE_DB_PATH=/data/polyclaw.db
POLYCLAW_DB_PATH=/data/polyclaw.db

# PostgreSQL (optional, for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/sincor2

# ============================================================================
# API Keys & Integrations
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYPAL_REST_API_ID=
PAYPAL_REST_API_SECRET=
RESEND_API_KEY=
WALLETCONNECT_PROJECT_ID=

# ============================================================================
# Google APIs (OAuth & Services)
# ============================================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_API_KEY=
GOOGLE_ADS_API_ID=
GOOGLE_ADS_API_KEY=

# ============================================================================
# GitHub Integration
# ============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# OAuth Redirect
# ============================================================================
OAUTH_REDIRECT_BASE_URL=https://getsincor.com
PUBLIC_BASE_URL=https://getsincor.com
SITE_URL=https://getsincor.com

# ============================================================================
# Twilio SMS
# ============================================================================
TWILIO_ID=
TWILIO_AUTH=
TWILIO_NUMBER=
ADMIN_SMS_NUMBER=

# ============================================================================
# Email
# ============================================================================
SMTP_HOST=smtp.resend.com
SMTP_USER=resend
SMTP_PASSWORD=${RESEND_API_KEY}
SUPPORT_EMAIL=support@getsincor.com

# ============================================================================
# Payments
# ============================================================================
LEGACY_FIAT_PAYMENTS_ENABLED=false
PAYPAL_ENV=live
PAYPAL_SANDBOX=false

# ============================================================================
# Crypto (Base Network)
# ============================================================================
BASE_PAYMENT_ADDRESS=0x09E2891432827D8835d2E9b83B25e2a5ba9612Ac
ETH_PRICE_FALLBACK=2500
WEB3_PROVIDER=https://mainnet.base.org

# ============================================================================
# Token Addresses (Base Mainnet)
# ============================================================================
SINC_ADDRESS=0x9C8cd8d3961F445D653713dE65C6578bE11668e7
AXIOM_ADDRESS=0xfF7aF6ffca25A9DC0FC990d998AcF24Cc60b7822
PLATFORM_TREASURY_ADDRESS=0x09E2891432827D8835d2E9b83B25e2a5ba9612Ac
TREASURY_ADDRESS=0x09E2891432827D8835d2E9b83B25e2a5ba9612Ac

# ============================================================================
# Polyclaw Live Trading (real stack: forecasting + bankroll + execution)
# ============================================================================
# GOING LIVE REQUIRES ALL OF:
#   1. POLYCLAW_LIVE=true
#   2. POLYMARKET_PRIVATE_KEY set (Polygon EOA funded with USDC + a little MATIC)
#   3. pip install py-clob-client
# Without ALL three the runner does the full scan/size loop as a DRY RUN only.
POLYCLAW_LIVE=false
POLYCLAW_LOOP=0
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com

# Incremental capital policy — NO fixed dollar ceiling. Start at $20 and every
# limit scales with equity (starting capital + realized profit):
#   $20    → ~$1–$3 wagers
#   $3,000 → ~$30–$300 wagers
# Stronger TOA/forecast confidence → larger fraction of the range, always.
POLYCLAW_CAPITAL_USD=20
POLYCLAW_MAX_POSITION_PCT=0.15
POLYCLAW_DAILY_LOSS_PCT=0.25
# Wager floor = Polymarket's ≈$1 exchange minimum.
POLYCLAW_MIN_WAGER_USD=1.0
POLYCLAW_MIN_EDGE=0.04
POLYCLAW_MIN_CONFIDENCE=0.4
POLYCLAW_KELLY_FRACTION=0.5
POLYCLAW_MAX_TRADES_PER_CYCLE=3
POLYCLAW_CYCLE_INTERVAL_SEC=90
POLYCLAW_HALT_FILE=/data/POLYCLAW_HALT

# Separate key for on-chain treasury ops (never reuse the CLOB key)
ONCHAIN_EXECUTOR_PRIVATE_KEY=

# ============================================================================
# Trading Risk Management (ENFORCED by bankroll.py, proportional to equity)
# ============================================================================
TRADING_MAX_DRAWDOWN=0.15
TRADING_MAX_LEVERAGE=2.0

# ============================================================================
# Agent Schedulers
# ============================================================================
OUTREACH_ENABLED=true
CONTENT_AGENT_ENABLED=false
DAILY_OPS_ENABLED=true
LAUNCH_OPS_ENABLED=true

# ============================================================================
# SADAS (Alternative Derivative Alpha Swarm)
# ============================================================================
SADAS_ENABLED=true
SADAS_INTERVAL_MINUTES=15
SADAS_MARKETS=Pre-IPO,Yield Stripping,Binary Primitive
TOA_SIMULATION_DEPTH=500
TOA_RISK_CAP=0.02
SADAS_MIN_TVL_USD=500000
SADAS_PROB_THRESHOLD=0.82

# ============================================================================
# Treasury Policy
# ============================================================================
TREASURY_CONVERSION_ENABLED=true
TREASURY_TARGET_ASSET=USDC
TREASURY_CONVERSION_SLIPPAGE_BPS=50
TREASURY_CONVERT_VIA=univ4|intent

# ============================================================================
# Platform Cache & Performance
# ============================================================================
PLATFORM_SPOT_CACHE_TTL_SEC=60

# ============================================================================
# Logging & Observability
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
OTLP_ENDPOINT=
TRACE_LEVEL=info

# ============================================================================
# WebBuilder (Optional)
# ============================================================================
WEBBUILDER_ENABLED=false
WEBBUILDER_DATA_DIR=/data/webbuilder
WEBBUILDER_PREVIEW_HOST=getsincor.com
YELP_API_KEY=
GOOGLE_PLACES_API_KEY=

# ============================================================================
# Subscriptions
# ============================================================================
SUBSCRIPTION_REMINDER_ENABLED=true
SUBSCRIPTION_REMINDER_HOUR=10
SUBSCRIPTION_REMINDER_MINUTE=0

# ============================================================================
# On-Chain Safety (NEVER enable on production)
# ============================================================================
AGENT_BURN_AUTO=false
ALLOW_ONCHAIN_WRITES=false
SAFETY_OVERRIDE=false
BILLING_FORWARDER_PRIVATE_KEY=

# ============================================================================
# Vault Event Listener (SharedLiquidityVault -> TOA feedback, read-only)
# ============================================================================
# Polls Base logs for Settled/DrawDown/FeesHarvested/Deposited/Withdrawn and
# feeds them into the TOA feedback loop. No private key required.
VAULT_LISTENER_ENABLED=false
VAULT_ADDRESS=0xeA90a257e5Dae20a0472C4812775F28614459bb6
# BASE_RPC_URL=   # falls back to WEB3_PROVIDER when unset
VAULT_POLL_INTERVAL_SEC=30
VAULT_CONFIRMATIONS=3
VAULT_LISTENER_STATE_PATH=/data/vault_listener_state.json
# VAULT_START_BLOCK=   # defaults to 2000 blocks back from head on first run
