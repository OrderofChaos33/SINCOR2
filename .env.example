# SINCOR Environment Variables — TEMPLATE ONLY
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Platform billing — SINC (subscriptions) + AXM (one-off intel) on Base
PLATFORM_TREASURY_ADDRESS=0x09E2891432827D8835d2E9b83B25e2a5ba9612Ac
AXM_USD_FALLBACK=
AXM_REPORT_PRICE=500
ETH_USD=3000
LEGACY_FIAT_PAYMENTS_ENABLED=false
PLATFORM_SPOT_CACHE_TTL_SEC=60

# Railway volume — mount at /data for orders.db, agent_burn_log, compliance logs
SINCOR_DATA_DIR=/data
ORDERS_DB_PATH=/data/orders.db

# SINC subscription renewal emails (wallet billing)
SUBSCRIPTION_REMINDER_ENABLED=true
SUBSCRIPTION_REMINDER_HOUR=10
SUBSCRIPTION_REMINDER_MINUTE=0

# Optional treasury burn forwarder (off until local forwarder wallet scripted)
AGENT_BURN_AUTO=false
BILLING_FORWARDER_PRIVATE_KEY=

# Legacy PayPal — only if LEGACY_FIAT_PAYMENTS_ENABLED=true
PAYPAL_REST_API_ID=
PAYPAL_REST_API_SECRET=
PAYPAL_ENV=live
PAYPAL_SANDBOX=false

# Legacy Stripe — only if LEGACY_FIAT_PAYMENTS_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_RETURN_URL=https://getsincor.com/billing

# Anthropic API
ANTHROPIC_API_KEY=

# Google APIs
GOOGLE_ADS_API_ID=
GOOGLE_ADS_API_KEY=
GOOGLE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Square (if using Square)
SQUARE_APP_ID=
SQUARE_APP_SECRET=

# Twilio SMS (Railway uses TWILIO_*; legacy TWILO_* also supported)
TWILIO_ID=
TWILIO_AUTH=
TWILIO_NUMBER=
ADMIN_SMS_NUMBER=
TWILO_AUTH=
TWILO_ID=
TWILO_NUMBER=

# Flask / App Security — REQUIRED in production
SECRET_KEY=
JWT_SECRET_KEY=
JWT_SECRET=

# Admin Credentials — REQUIRED in production (no defaults)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Email Delivery (Resend, SMTP, etc.)
RESEND_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SUPPORT_EMAIL=support@getsincor.com

# Crypto Payments (Base network)
BASE_PAYMENT_ADDRESS=
ETH_PRICE_FALLBACK=10000

# --- Schedulers (Railway) — enable only what you need ---
# Launch content → /launch/review (pick Railway OR Windows daily task, not both)
LAUNCH_OPS_ENABLED=false
LAUNCH_OPS_INTERVAL_HOURS=24

# Daily ~5 min approval reminder email
LAUNCH_REVIEW_ALERT_EMAIL=eenergy@protonmail.com
LAUNCH_REVIEW_REMINDER_ENABLED=true
LAUNCH_REVIEW_REMINDER_HOUR=9
LAUNCH_REVIEW_REMINDER_MINUTE=15
LAUNCH_REVIEW_REMINDER_AFTER_CYCLE=true

# Read-only daily monitoring (chain, revenue, wallet watch)
DAILY_OPS_ENABLED=false
DAILY_OPS_INTERVAL_HOURS=24
DAILY_OPS_BUYERS_WEEKLY=true
WALLET_WATCH_LIST=

# Compliance audit (marketing claims, env creds) — every 30 min
COMPLIANCE_MONITOR_ENABLED=true
SLACK_COMPLIANCE_WEBHOOK_URL=
COMPLIANCE_ALERT_EMAIL=

# SEO blog agent (48h, can auto-publish to WordPress)
CONTENT_AGENT_ENABLED=false
CONTENT_INTERVAL_HOURS=48

# Cold outreach email (6h)
OUTREACH_ENABLED=false
OUTREACH_INTERVAL_HOURS=6

# WebBuilder Studio (mount Railway volume at /data/webbuilder)
WEBBUILDER_DATA_DIR=/data/webbuilder
WEBBUILDER_PREVIEW_HOST=getsincor.com
YELP_API_KEY=
GOOGLE_PLACES_API_KEY=

# Polyclaw trading scan — off by default until wired
POLYCLAW_ENABLED=false
POLYCLAW_AUTO_EXECUTE=false

# Farcaster (posts on /launch/review approve)
NEYNAR_API_KEY=
FARCASTER_SIGNER_UUID=

# Buy watcher SMS (Windows logon task with -BuyWatcher)
NOTIFY_PHONE=
TWILIO_SID=
TWILIO_AUTH=
TWILIO_FROM=
BASE_RPC_URL=

# Railway / Deployment
PORT=8080
FLASK_ENV=production
RAILWAY_ENVIRONMENT=production
