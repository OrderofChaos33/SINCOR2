# SINCOR Environment Variables Template
# Copy this to .env and fill in your actual values

# ====================
# CORE APPLICATION
# ====================
FLASK_ENV=production
PORT=5000
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ====================
# CLAUDE AI API
# ====================
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ====================
# PAYPAL CONFIGURATION
# ====================
PAYPAL_REST_API_ID=your-paypal-client-id
PAYPAL_REST_API_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox  # Change to 'live' for production
PAYPAL_SANDBOX=true  # Change to 'false' for production
PAYPAL_RETURN_URL=https://yourdomain.com/api/paypal/execute
PAYPAL_CANCEL_URL=https://yourdomain.com/pricing

# ====================
# STRIPE CONFIGURATION
# ====================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID=price_starter_monthly_id
STRIPE_PRO_PRICE_ID=price_pro_monthly_id
STRIPE_BUSINESS_PRICE_ID=price_business_monthly_id
STRIPE_OPERATIONS_PRICE_ID=price_operations_metered_id
STRIPE_API_PRICE_ID=price_api_calls_metered_id
STRIPE_AGENTS_PRICE_ID=price_agents_metered_id

# ====================
# DATABASE (if needed)
# ====================
DATABASE_URL=postgresql://user:password@host:port/database
# or
# MONGODB_URI=mongodb://user:password@host:port/database

# ====================
# REDIS (for rate limiting, optional)
# ====================
REDIS_URL=redis://localhost:6379/0

# ====================
# EMAIL CONFIGURATION
# ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
FROM_EMAIL=noreply@getsincor.com

# ====================
# SOCIAL MEDIA APIs (optional)
# ====================
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@your-channel-name

# ====================
# MONITORING & ANALYTICS
# ====================
SENTRY_DSN=your-sentry-dsn-for-error-tracking
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# ====================
# CORS ORIGINS
# ====================
ALLOWED_ORIGINS=https://getsincor.com,https://www.getsincor.com

# ====================
# RATE LIMITING
# ====================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
