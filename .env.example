# ============================================================================
# SINCOR2 Environment Configuration Template
# ============================================================================
# Copy this to .env and fill in real values before deployment
# NEVER commit .env to version control

# ============================================================================
# Flask & Security
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256

# ============================================================================
# Admin Credentials (Change immediately after first login)
# ============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe!12345

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8080
HOST=0.0.0.0
WORKERS=2
TIMEOUT=180
TRUST_PROXY=true
RAILWAY_ENVIRONMENT=

# ============================================================================
# Database
# ============================================================================
SINCOR_DATA_DIR=/data
ORDERS_DB_PATH=/data/orders.db
DATABASE_URL=sqlite:////data/orders.db

# PostgreSQL (optional, for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/sincor2

# ============================================================================
# API Keys & Integrations
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYPAL_REST_API_ID=
PAYPAL_REST_API_SECRET=
RESEND_API_KEY=
WALLETCONNECT_PROJECT_ID=

# ============================================================================
# Google APIs (OAuth & Services)
# ============================================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_API_KEY=
GOOGLE_ADS_API_ID=
GOOGLE_ADS_API_KEY=

# ============================================================================
# GitHub Integration
# ============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# OAuth Redirect
# ============================================================================
OAUTH_REDIRECT_BASE_URL=https://getsincor.com
PUBLIC_BASE_URL=https://getsincor.com
SITE_URL=https://getsincor.com

# ============================================================================
# Twilio SMS
# ============================================================================
TWILIO_ID=
TWILIO_AUTH=
TWILIO_NUMBER=
ADMIN_SMS_NUMBER=

# ============================================================================
# Email
# ============================================================================
SMTP_HOST=smtp.resend.com
SMTP_USER=resend
SMTP_PASSWORD=${RESEND_API_KEY}
SUPPORT_EMAIL=support@getsincor.com

# ============================================================================
# Payments
# ============================================================================
LEGACY_FIAT_PAYMENTS_ENABLED=false
PAYPAL_ENV=live
PAYPAL_SANDBOX=false

# ============================================================================
# Crypto (Base Network)
# ============================================================================
BASE_PAYMENT_ADDRESS=0x09E2891432827D8835d2E9b83B25e2a5ba9612Ac
ETH_PRICE_FALLBACK=2500
WEB3_PROVIDER=https://mainnet.base.org

# ============================================================================
# Token Addresses (Base Mainnet)
# ============================================================================
SINC_ADDRESS=0x9C8cd8d3961F445D653713dE65C6578bE11668e7
AXIOM_ADDRESS=0xfF7aF6ffca25A9DC0FC990d998AcF24Cc60b7822
PLATFORM_TREASURY_ADDRESS=0x09E2891432827D8835d2E9b83B25e2a5ba9612Ac

# ============================================================================
# Trading Configuration
# ============================================================================
POLYCLAW_ENABLED=true
POLYCLAW_AUTO_EXECUTE=false
POLYCLAW_CAPITAL=25000
MM_POSITION_SIZE=50000

# ============================================================================
# Trading Risk Management
# ============================================================================
TRADING_MAX_DRAWDOWN=0.15
TRADING_MAX_LEVERAGE=2.0

# ============================================================================
# Agent Schedulers
# ============================================================================
OUTREACH_ENABLED=true
CONTENT_AGENT_ENABLED=false
DAILY_OPS_ENABLED=true
LAUNCH_OPS_ENABLED=false

# ============================================================================
# SADAS (Alternative Derivative Alpha Swarm)
# ============================================================================
SADAS_ENABLED=true
SADAS_INTERVAL_MINUTES=15
SADAS_MARKETS=Pre-IPO,Yield Stripping,Binary Primitive
TOA_SIMULATION_DEPTH=500
TOA_RISK_CAP=0.02
SADAS_MIN_TVL_USD=500000
SADAS_PROB_THRESHOLD=0.82

# ============================================================================
# Treasury Policy
# ============================================================================
TREASURY_CONVERSION_ENABLED=true
TREASURY_TARGET_ASSET=USDC
TREASURY_CONVERSION_SLIPPAGE_BPS=50
TREASURY_CONVERT_VIA=univ4|intent

# ============================================================================
# Platform Cache & Performance
# ============================================================================
PLATFORM_SPOT_CACHE_TTL_SEC=60

# ============================================================================
# Logging & Observability
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
OTLP_ENDPOINT=
TRACE_LEVEL=info

# ============================================================================
# WebBuilder (Optional)
# ============================================================================
WEBBUILDER_ENABLED=false
WEBBUILDER_DATA_DIR=/data/webbuilder
WEBBUILDER_PREVIEW_HOST=getsincor.com
YELP_API_KEY=
GOOGLE_PLACES_API_KEY=

# ============================================================================
# Subscriptions
# ============================================================================
SUBSCRIPTION_REMINDER_ENABLED=true
SUBSCRIPTION_REMINDER_HOUR=10
SUBSCRIPTION_REMINDER_MINUTE=0

# ============================================================================
# On-Chain Safety (NEVER enable on production)
# ============================================================================
AGENT_BURN_AUTO=false
ALLOW_ONCHAIN_WRITES=false
SAFETY_OVERRIDE=false
BILLING_FORWARDER_PRIVATE_KEY=
