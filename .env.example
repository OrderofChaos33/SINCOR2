# SINCOR Environment Variables — TEMPLATE ONLY
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# PayPal Live Credentials (set these in Railway dashboard, not here)
PAYPAL_REST_API_ID=
PAYPAL_REST_API_SECRET=
PAYPAL_ENV=live
PAYPAL_SANDBOX=false

# Stripe (if using Stripe integration)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_RETURN_URL=https://getsincor.com/billing

# Anthropic API
ANTHROPIC_API_KEY=

# Google APIs
GOOGLE_ADS_API_ID=
GOOGLE_ADS_API_KEY=
GOOGLE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Square (if using Square)
SQUARE_APP_ID=
SQUARE_APP_SECRET=

# Twilio SMS (if using Twilio)
TWILO_AUTH=
TWILO_ID=
TWILO_NUMBER=

# Flask / App Security — REQUIRED in production
SECRET_KEY=
JWT_SECRET_KEY=
JWT_SECRET=

# Admin Credentials — REQUIRED in production (no defaults)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Email Delivery (Resend, SMTP, etc.)
RESEND_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SUPPORT_EMAIL=support@getsincor.com

# Crypto Payments (Base network)
BASE_PAYMENT_ADDRESS=
ETH_PRICE_FALLBACK=10000

# ── On-chain / A2A integration ───────────────────────────────────────────────
# Base mainnet RPC (Alchemy, Infura, Ankr, etc.) — required for payment verify
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=
BASESCAN_API_KEY=

# SINC token (Base mainnet, ERC-20, 8 decimals, 100 M supply)
SINC_CONTRACT_ADDRESS=0x9C8cd8d3961F445D653713dE65C6578bE11668e7
# SinCurve bonding-curve contract (Base mainnet)
SINC_BONDING_CURVE_ADDRESS=0x75dE341a2BC81806198364F125d4Cde36527619C

# AXIOM token (Base mainnet, ERC-20, 18 decimals, 1 B supply)
AXIOM_CONTRACT_ADDRESS=0xfF7aF6ffca25A9DC0FC990d998AcF24Cc60b7822

# Treasury wallet (public — never put the private key here)
TREASURY_ADDRESS=0xAf9B539D8043C634b7E611818518BA7E850F289e

# AXM price per A2A task call, in wei (18 decimals).  Default = 1 AXM.
AXM_PRICE_PER_TASK=1000000000000000000

# Base chain ID (8453 = Base mainnet, 84532 = Base Sepolia)
BASE_CHAIN_ID=8453

# Public platform URL (used in /.well-known/agent.json AgentCard)
PLATFORM_URL=https://getsincor.com

# Railway / Deployment
PORT=8080
FLASK_ENV=production
RAILWAY_ENVIRONMENT=production
