# SINCOR Environment Variables — TEMPLATE ONLY
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# === STRATEGIC FOCUS (as of June 2026) ===
# All-in on highest-ROI surfaces: SADAS (financial alpha), Trading edge (Polyclaw/TOA), 
# Outreach, Content, Core A2A + high-margin verticals, Risk-Compliance B2B.
# Lower-leverage / higher-maintenance items (e.g. WebBuilder) are paused unless fully autonomous.

# Platform billing — SINC (subscriptions) + AXM (one-off intel) on Base
PLATFORM_TREASURY_ADDRESS=0x09E2891432827D8835d2E9b83B25e2a5ba9612Ac
AXM_USD_FALLBACK=
AXM_REPORT_PRICE=500
ETH_USD=3000
LEGACY_FIAT_PAYMENTS_ENABLED=false
PLATFORM_SPOT_CACHE_TTL_SEC=60

# Railway volume — mount at /data for orders.db, agent_burn_log, compliance logs
SINCOR_DATA_DIR=/data
ORDERS_DB_PATH=/data/orders.db

# SINC subscription renewal emails (wallet billing)
SUBSCRIPTION_REMINDER_ENABLED=true
SUBSCRIPTION_REMINDER_HOUR=10
SUBSCRIPTION_REMINDER_MINUTE=0

# On-chain writes — NEVER enable on Railway production (local scripts only)
AGENT_BURN_AUTO=false
BILLING_FORWARDER_PRIVATE_KEY=
ALLOW_ONCHAIN_WRITES=false
SAFETY_OVERRIDE=false

# Legacy PayPal — only if LEGACY_FIAT_PAYMENTS_ENABLED=true
PAYPAL_REST_API_ID=
PAYPAL_REST_API_SECRET=
PAYPAL_ENV=live
PAYPAL_SANDBOX=false

# Legacy Stripe — only if LEGACY_FIAT_PAYMENTS_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_RETURN_URL=https://getsincor.com/billing

# Anthropic API
ANTHROPIC_API_KEY=

# Google APIs
GOOGLE_ADS_API_ID=
GOOGLE_ADS_API_KEY=
GOOGLE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=https://getsincor.com

# WalletConnect / Reown
WALLETCONNECT_PROJECT_ID=

# Twilio SMS
TWILIO_ID=
TWILIO_AUTH=
TWILIO_NUMBER=
ADMIN_SMS_NUMBER=

# Flask / App Security
SECRET_KEY=
JWT_SECRET_KEY=

# Admin Credentials
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Email Delivery
RESEND_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SUPPORT_EMAIL=support@getsincor.com

# Crypto Payments (Base network)
BASE_PAYMENT_ADDRESS=
ETH_PRICE_FALLBACK=10000

# === SADAS (Alternative Derivative Alpha Swarm) ===
SADAS_ENABLED=true
SADAS_INTERVAL_MINUTES=15
SADAS_MARKETS=Pre-IPO,Yield Stripping,Binary Primitive
TOA_SIMULATION_DEPTH=500
TOA_RISK_CAP=0.02
SADAS_MIN_TVL_USD=500000
SADAS_PROB_THRESHOLD=0.82

# === Treasury Policy (Hard Rule) ===
TREASURY_CONVERSION_ENABLED=true
TREASURY_TARGET_ASSET=USDC
TREASURY_CONVERSION_SLIPPAGE_BPS=50
TREASURY_CONVERT_VIA=univ4|intent

# Active Trading Wallets Exception (keep/syphon native AXM/SINC)
TRADING_WALLET_ADDRESSES=
SYPHON_PROFIT_INTERVAL_TRADES=50
SYPHON_PROFIT_THRESHOLD_USD=2500

# === Revenue Schedulers (enabled for autonomous operation) ===
POLYCLAW_ENABLED=true
POLYCLAW_AUTO_EXECUTE=true
OUTREACH_ENABLED=true
CONTENT_AGENT_ENABLED=true
DAILY_OPS_ENABLED=true
LAUNCH_OPS_ENABLED=true

# === Lower-leverage / Paused (WebBuilder and similar) ===
# These are paused to focus on highest-ROI surfaces. Re-enable only if fully autonomous.
WEBBUILDER_DATA_DIR=/data/webbuilder
WEBBUILDER_PREVIEW_HOST=getsincor.com
YELP_API_KEY=
GOOGLE_PLACES_API_KEY=
WEBBUILDER_ENABLED=false

# Railway / Deployment
PORT=8080
FLASK_ENV=production
RAILWAY_ENVIRONMENT=production
